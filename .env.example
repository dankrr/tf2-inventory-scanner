STEAM_API_KEY=your_steam_key_here
BPTF_API_KEY=your_backpack_key_here
# Optional backward-compatible alias for older setups.
BACKPACK_TF_API_KEY=
FLASK_SECRET_KEY=replace_with_random_secret
CACHE_RETRIES=2
CACHE_DELAY=2
SKIP_CACHE_INIT=0
# Set to 0 to disable Steam CDN image resolution for Australium/War Paint variants.
# Disable if Steam Market is rate-limiting you aggressively.
CDN_RESOLVER_ENABLED=1
